{
  "expo": {
    "name": "music.log",
    "slug": "music-log",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#EAF0F5"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.lucasfranca.musiclog"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#213C51"
      },
      "edgeToEdgeEnabled": true,
      "package": "com.lucasfranca.musiclog"
    },
    "web": {
      "bundler": "metro",
      "favicon": "./assets/favicon.png",
      "name": "music.log",
      "shortName": "music.log",
      "description": "Piano practice session logger",
      "themeColor": "#213C51",
      "backgroundColor": "#EAF0F5",
      "display": "standalone",
      "orientation": "portrait",
      "scope": "/",
      "startUrl": "/"
    },
    "plugins": [
      "expo-sqlite",
      "expo-font"
    ]
  }
}
